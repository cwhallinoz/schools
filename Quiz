
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grief Management Readiness in Schools | Grief Australia</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #45423D;
    --ink-light: #6B6762;
    --cream: #FAF8F5;
    --warm-white: #FFFFFF;
    --accent: #7A6B5A;
    --accent-light: #C4B8AC;
    --anchor-a: #8B6F5E;
    --anchor-n: #6B7B6E;
    --anchor-c: #5E6B7B;
    --anchor-h: #7B6E5E;
    --anchor-o: #5E7B72;
    --anchor-r: #7B5E6B;
    --border: #E8E3DC;
    --shadow: rgba(69, 66, 61, 0.08);
    --shadow-med: rgba(69, 66, 61, 0.14);
    --progress-bg: #EDE8E2;
    --progress-fill: #7A6B5A;
    --limited: #C0392B;
    --emerging: #E67E22;
    --consolidating: #2980B9;
    --strong: #27AE60;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Poppins', sans-serif;
    background: var(--cream);
    color: var(--ink);
    min-height: 100vh;
  }

  /* HEADER */
  .site-header {
    background: var(--warm-white);
    border-bottom: 1px solid var(--border);
    padding: 18px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px var(--shadow);
  }

  .logo-area {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-mark {
    width: 38px;
    height: 38px;
    background: var(--ink);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-mark svg {
    width: 20px;
    height: 20px;
  }

  .logo-text {
    font-weight: 700;
    font-size: 15px;
    color: var(--ink);
    letter-spacing: -0.2px;
  }

  .logo-sub {
    font-weight: 300;
    font-size: 11px;
    color: var(--ink-light);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    display: block;
  }

  .progress-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .progress-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-light);
  }

  .progress-bar-wrap {
    width: 160px;
    height: 6px;
    background: var(--progress-bg);
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: var(--progress-fill);
    border-radius: 3px;
    transition: width 0.4s ease;
  }

  .progress-count {
    font-size: 12px;
    font-weight: 600;
    color: var(--ink);
    min-width: 32px;
    text-align: right;
  }

  /* MAIN LAYOUT */
  .main-wrap {
    max-width: 780px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  /* INTRO SCREEN */
  .intro-screen {
    text-align: center;
    padding: 20px 0 40px;
  }

  .intro-badge {
    display: inline-block;
    background: var(--ink);
    color: var(--warm-white);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 20px;
    margin-bottom: 28px;
  }

  .intro-screen h1 {
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: 16px;
    letter-spacing: -0.5px;
  }

  .intro-screen h1 span {
    display: block;
    font-weight: 300;
    font-size: 0.72em;
    color: var(--ink-light);
    letter-spacing: 0px;
    margin-top: 4px;
  }

  .intro-desc {
    font-size: 15px;
    font-weight: 400;
    color: var(--ink-light);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 36px;
  }

  .intro-meta {
    display: flex;
    justify-content: center;
    gap: 28px;
    margin-bottom: 44px;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-light);
  }

  .meta-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-light);
    flex-shrink: 0;
  }

  .btn-start {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--ink);
    color: var(--warm-white);
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 16px 40px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    letter-spacing: 0.2px;
    transition: all 0.2s ease;
    box-shadow: 0 4px 16px var(--shadow-med);
  }

  .btn-start:hover {
    background: #2A2824;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px var(--shadow-med);
  }

  .btn-start svg {
    transition: transform 0.2s ease;
  }

  .btn-start:hover svg {
    transform: translateX(3px);
  }

  /* SECTION HEADERS */
  .section-header {
    margin-bottom: 20px;
  }

  .section-number {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 6px;
    display: block;
  }

  .section-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .section-subtitle {
    font-size: 13px;
    font-weight: 400;
    color: var(--ink-light);
  }

  .section-divider {
    height: 1px;
    background: var(--border);
    margin: 10px 0 28px;
  }

  /* QUESTION CARDS */
  .question-card {
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 28px;
    margin-bottom: 16px;
    box-shadow: 0 2px 8px var(--shadow);
    transition: box-shadow 0.2s ease;
  }

  .question-card:hover {
    box-shadow: 0 4px 16px var(--shadow-med);
  }

  .q-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .q-text {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.55;
    margin-bottom: 20px;
  }

  /* SCALE BUTTONS */
  .scale-wrap {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .scale-option {
    position: relative;
  }

  .scale-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .scale-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 12px 8px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.15s ease;
    text-align: center;
    min-height: 68px;
  }

  .scale-label:hover {
    border-color: var(--accent-light);
    background: #FAF8F5;
  }

  .scale-num {
    font-size: 18px;
    font-weight: 700;
    color: var(--accent-light);
    transition: color 0.15s ease;
    line-height: 1;
  }

  .scale-text {
    font-size: 10px;
    font-weight: 500;
    color: var(--ink-light);
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .scale-option input:checked + .scale-label {
    border-color: var(--ink);
    background: var(--ink);
  }

  .scale-option input:checked + .scale-label .scale-num {
    color: var(--warm-white);
  }

  .scale-option input:checked + .scale-label .scale-text {
    color: rgba(255,255,255,0.8);
  }

  /* SECTION GROUP */
  .section-group {
    margin-bottom: 40px;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* NAVIGATION */
  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .btn-nav {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 600;
    padding: 12px 24px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
  }

  .btn-back {
    background: transparent;
    color: var(--ink-light);
    border: 1.5px solid var(--border);
  }

  .btn-back:hover {
    color: var(--ink);
    border-color: var(--accent-light);
    background: var(--warm-white);
  }

  .btn-next {
    background: var(--ink);
    color: var(--warm-white);
    box-shadow: 0 2px 10px var(--shadow-med);
  }

  .btn-next:hover {
    background: #2A2824;
    transform: translateY(-1px);
  }

  .btn-next:disabled {
    background: var(--accent-light);
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .step-indicator {
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-light);
  }

  /* RESULTS */
  .results-screen {
    animation: fadeIn 0.4s ease;
  }

  .results-hero {
    text-align: center;
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 40px 36px;
    margin-bottom: 36px;
    box-shadow: 0 4px 20px var(--shadow);
  }

  .results-hero .intro-badge {
    margin-bottom: 20px;
  }

  .results-hero h2 {
    font-size: 26px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 10px;
    letter-spacing: -0.3px;
  }

  .overall-band {
    display: inline-block;
    font-size: 15px;
    font-weight: 600;
    padding: 8px 24px;
    border-radius: 24px;
    margin-bottom: 20px;
    letter-spacing: 0.2px;
  }

  .band-limited { background: #FDE8E6; color: var(--limited); }
  .band-emerging { background: #FEF3E2; color: var(--emerging); }
  .band-consolidating { background: #E8F1FA; color: var(--consolidating); }
  .band-strong { background: #E6F5ED; color: var(--strong); }

  .results-hero p {
    font-size: 14px;
    font-weight: 400;
    color: var(--ink-light);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto;
  }

  /* ANCHOR GRID */
  .anchor-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 36px;
  }

  @media (max-width: 560px) {
    .anchor-grid { grid-template-columns: 1fr; }
    .scale-wrap { grid-template-columns: repeat(2, 1fr); }
    .site-header { padding: 14px 20px; }
    .main-wrap { padding: 32px 16px 60px; }
    .intro-meta { gap: 16px; }
    .progress-header { display: none; }
  }

  .anchor-card {
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 22px 22px 18px;
    box-shadow: 0 2px 8px var(--shadow);
    position: relative;
    overflow: hidden;
  }

  .anchor-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
  }

  .anchor-A::before { background: var(--anchor-a); }
  .anchor-N::before { background: var(--anchor-n); }
  .anchor-C::before { background: var(--anchor-c); }
  .anchor-H::before { background: var(--anchor-h); }
  .anchor-O::before { background: var(--anchor-o); }
  .anchor-R::before { background: var(--anchor-r); }

  .anchor-letter {
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 2px;
  }

  .anchor-A .anchor-letter { color: var(--anchor-a); }
  .anchor-N .anchor-letter { color: var(--anchor-n); }
  .anchor-C .anchor-letter { color: var(--anchor-c); }
  .anchor-H .anchor-letter { color: var(--anchor-h); }
  .anchor-O .anchor-letter { color: var(--anchor-o); }
  .anchor-R .anchor-letter { color: var(--anchor-r); }

  .anchor-name {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3px;
    color: var(--ink-light);
    margin-bottom: 14px;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 1px;
  }

  .domain-score-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .domain-score-num {
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
  }

  .domain-score-max {
    font-size: 13px;
    font-weight: 400;
    color: var(--ink-light);
  }

  .domain-band-pill {
    font-size: 10px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 12px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }

  .score-bar-wrap {
    height: 6px;
    background: var(--progress-bg);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 14px;
  }

  .score-bar-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .anchor-A .score-bar-fill { background: var(--anchor-a); }
  .anchor-N .score-bar-fill { background: var(--anchor-n); }
  .anchor-C .score-bar-fill { background: var(--anchor-c); }
  .anchor-H .score-bar-fill { background: var(--anchor-h); }
  .anchor-O .score-bar-fill { background: var(--anchor-o); }
  .anchor-R .score-bar-fill { background: var(--anchor-r); }

  .anchor-feedback {
    font-size: 12px;
    font-weight: 400;
    color: var(--ink-light);
    line-height: 1.55;
  }

  /* PRIORITY ACTIONS */
  .priority-section {
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 28px;
    margin-bottom: 28px;
    box-shadow: 0 2px 8px var(--shadow);
  }

  .priority-section h3 {
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .priority-item {
    display: flex;
    gap: 14px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .priority-item:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .priority-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--warm-white);
    font-size: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .priority-content h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 3px;
  }

  .priority-content p {
    font-size: 12px;
    font-weight: 400;
    color: var(--ink-light);
    line-height: 1.55;
  }

  /* CTA FOOTER */
  .cta-box {
    background: var(--ink);
    border-radius: 16px;
    padding: 36px 36px;
    text-align: center;
    color: var(--warm-white);
  }

  .cta-box h3 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 10px;
    letter-spacing: -0.2px;
  }

  .cta-box p {
    font-size: 13px;
    font-weight: 300;
    opacity: 0.8;
    margin-bottom: 24px;
    line-height: 1.6;
    max-width: 460px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-links {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 600;
    padding: 12px 22px;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
    border: none;
  }

  .btn-cta-primary {
    background: var(--warm-white);
    color: var(--ink);
  }

  .btn-cta-primary:hover {
    background: #F0EDE8;
    transform: translateY(-1px);
  }

  .btn-cta-outline {
    background: transparent;
    color: var(--warm-white);
    border: 1.5px solid rgba(255,255,255,0.35);
  }

  .btn-cta-outline:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.6);
  }

  .btn-restart {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-light);
    background: transparent;
    border: none;
    cursor: pointer;
    margin-top: 24px;
    padding: 8px 0;
    transition: color 0.2s ease;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .btn-restart:hover { color: var(--ink); }

  /* VALIDATION */
  .validation-msg {
    font-size: 12px;
    color: var(--limited);
    font-weight: 500;
    margin-top: 12px;
    display: none;
    padding: 10px 14px;
    background: #FDE8E6;
    border-radius: 6px;
  }

  .validation-msg.show { display: block; }

  /* PAGE transitions */
  .page { display: none; }
  .page.active { display: block; }

  /* DISCLAIMER */
  .disclaimer {
    font-size: 11px;
    color: var(--ink-light);
    text-align: center;
    margin-top: 36px;
    line-height: 1.6;
    opacity: 0.75;
  }
</style>
</head>
<body>

<header class="site-header">
  <div class="logo-area">
    <div class="logo-mark">
      <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 3C6.13 3 3 6.13 3 10s3.13 7 7 7 7-3.13 7-7-3.13-7-7-7zm0 2.5a2 2 0 110 4 2 2 0 010-4zm0 9.5c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08A7.16 7.16 0 0110 15z" fill="#FAF8F5"/>
      </svg>
    </div>
    <div>
      <div class="logo-text">Grief Australia</div>
      <span class="logo-sub">www.grief.org.au</span>
    </div>
  </div>
  <div class="progress-header" id="progressHeader" style="display:none">
    <span class="progress-label">Progress</span>
    <div class="progress-bar-wrap">
      <div class="progress-bar-fill" id="progressFill" style="width:0%"></div>
    </div>
    <span class="progress-count" id="progressCount">0 / 18</span>
  </div>
</header>

<div class="main-wrap">

  <!-- INTRO PAGE -->
  <div class="page active" id="page-intro">
    <div class="intro-screen">
      <span class="intro-badge">School Readiness Assessment</span>
      <h1>How grief-ready is your school?
        <span>A self-assessment for school leaders and teachers</span>
      </h1>
      <p class="intro-desc">Bereavement affects one in five students during their school years. This 18-question assessment helps you identify where your school is strong and where practical action is needed most. It takes around six minutes to complete.</p>
      <div class="intro-meta">
        <div class="meta-item"><div class="meta-dot"></div>18 questions across 6 areas</div>
        <div class="meta-item"><div class="meta-dot"></div>Approx. 6 minutes</div>
        <div class="meta-item"><div class="meta-dot"></div>Instant personalised results</div>
        <div class="meta-item"><div class="meta-dot"></div>No sign-up required</div>
      </div>
      <button class="btn-start" id="btnStart" onclick="startQuiz()">
        Begin assessment
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <!-- QUIZ PAGES (generated by JS) -->
  <div class="page" id="page-quiz">
    <div id="quizContent"></div>
    <div class="validation-msg" id="validationMsg">Please rate each item before continuing.</div>
    <div class="nav-bar">
      <button class="btn-nav btn-back" id="btnBack" onclick="goBack()">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13 8H3M7 12L3 8l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Back
      </button>
      <span class="step-indicator" id="stepIndicator"></span>
      <button class="btn-nav btn-next" id="btnNext" onclick="goNext()">
        Next
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <!-- RESULTS PAGE -->
  <div class="page" id="page-results">
    <div class="results-screen" id="resultsContent"></div>
  </div>

</div>

<script>
const SECTIONS = [
  {
    id: 'O',
    title: 'Policy and Procedures',
    subtitle: 'Organisational systems',
    questions: [
      { id: 1, text: 'Does your school have a written grief and bereavement policy that clearly describes how deaths affecting students or staff are managed?' },
      { id: 2, text: 'Is this policy known to staff and accessible in your usual policy repositories such as your intranet or staff handbook?' },
      { id: 3, text: 'Does your school have clear step-by-step procedures for verifying a death, consulting with the family and planning the school response?' },
    ]
  },
  {
    id: 'A',
    title: 'Staff Training and Confidence',
    subtitle: 'Awareness of grief and its impacts',
    questions: [
      { id: 4, text: 'Have staff at your school undertaken specific training on how to support grieving children and adolescents?' },
      { id: 5, text: 'How confident do staff feel having one-to-one conversations with students who have experienced a significant loss?' },
      { id: 6, text: 'How confident do staff feel in recognising when a student\'s behaviour or academic changes may be related to grief rather than misconduct or disengagement?' },
    ]
  },
  {
    id: 'A2',
    title: 'Identification, Monitoring and Adjustments',
    subtitle: 'Awareness and normalisation over time',
    questions: [
      { id: 7, text: 'Does your school systematically identify and keep track of students who have experienced a recent significant bereavement?' },
      { id: 8, text: 'Do you have agreed processes for monitoring academic progress, attendance and wellbeing of bereaved students over time, not only in the immediate aftermath?' },
      { id: 9, text: 'Are there clear guidelines for reasonable academic adjustments such as extended deadlines, workload reduction and assessment flexibility for students who are grieving?' },
    ]
  },
  {
    id: 'C',
    title: 'Classroom and Whole-School Response',
    subtitle: 'Communication with students, families and community',
    questions: [
      { id: 10, text: 'Do classroom teachers receive guidance on how to talk with a class about the death of a student, staff member or community member?' },
      { id: 11, text: 'Are there written templates or agreed communications for informing parents and carers about a death affecting the school community?' },
      { id: 12, text: 'Does your school have a plan for setting up support spaces such as counselling rooms or quiet areas following a significant death?' },
    ]
  },
  {
    id: 'H',
    title: 'Resources and Support for Staff',
    subtitle: 'Holding environment and staff wellbeing',
    questions: [
      { id: 13, text: 'What resources are available to assist teachers with supporting grieving children, such as guides, websites or classroom materials?' },
      { id: 14, text: 'Do staff have access to in-school expert consultation, such as a school psychologist, counsellor or wellbeing leader, when uncertain about how to support a bereaved student?' },
      { id: 15, text: 'Are there supports in place for staff who are themselves affected by a death, such as opportunities for debriefing, access to an employee assistance programme or relief time?' },
    ]
  },
  {
    id: 'R',
    title: 'External Partnerships and Review',
    subtitle: 'Referral, coordination and review',
    questions: [
      { id: 16, text: 'Does your school have established relationships with external mental health or bereavement services for referral when students need more intensive support?' },
      { id: 17, text: 'After a significant death, does your school formally review what worked well and what needs strengthening in its response?' },
      { id: 18, text: 'Is there a plan for recognising ongoing grief at key milestones such as anniversaries and graduations in a way that is consistent and inclusive?' },
    ]
  }
];

const SCALE_LABELS = ['Not in place', 'In development', 'Mostly in place', 'Fully in place'];

const ANCHOR_DOMAINS = {
  A:  { label: 'Awareness', items: [4,5,6,7,8], color: 'anchor-A' },
  N:  { label: 'Normalisation', items: [8,9,18], color: 'anchor-N' },
  C:  { label: 'Communication', items: [10,11,16], color: 'anchor-C' },
  H:  { label: 'Holding Environment', items: [6,9,12,15], color: 'anchor-H' },
  O:  { label: 'Organisational Systems', items: [1,2,3,17], color: 'anchor-O' },
  R:  { label: 'Referral and Review', items: [14,16,17,18], color: 'anchor-R' }
};

const DOMAIN_FEEDBACK = {
  A: {
    low:  'Staff awareness of grief and its impact on learning and behaviour is limited. Many bereaved students may not be identified or understood. Whole-school professional learning focused on childhood grief prevalence and developmental differences should be a priority.',
    high: 'Your staff demonstrate growing or strong awareness of how grief affects students. Embed this awareness into staff induction and annual refreshers so it remains consistent over time.',
    priorities_low: [
      { title: 'Provide whole-school professional learning on childhood grief', desc: 'Focus on prevalence data and how grief presents differently across developmental stages.' },
      { title: 'Create a brief guide for all staff', desc: 'Cover the academic, behavioural and social indicators that may signal grief rather than disengagement or misconduct.' }
    ]
  },
  N: {
    low:  'Grief may be treated as a short-term event. Students may not receive permission or space to acknowledge their loss over time, which can compound its impact on learning and wellbeing.',
    high: 'Your school has practices that recognise grief as an ongoing experience. Document these and share examples to maintain consistency across class levels.',
    priorities_low: [
      { title: 'Integrate grief content into wellbeing or social-emotional learning curricula', desc: 'This prepares all students, not only those currently bereaved.' },
      { title: 'Establish quiet, consistent routines for acknowledging anniversaries', desc: 'Guided by families and students, these should be low-key and inclusive rather than performative.' }
    ]
  },
  C: {
    low:  'Staff may be uncertain how to talk with students, families and peers about death. Without shared language and prepared communications, responses are often inconsistent and families may feel unsupported.',
    high: 'You have a solid communication base. Regularly refresh staff skills, ensure new and relief staff receive training and review templates after each incident.',
    priorities_low: [
      { title: 'Develop scripts and templates for student announcements and parent communications', desc: 'Include a prepared media statement. Rehearse these in training scenarios rather than producing them for the first time during a crisis.' },
      { title: 'Offer practical communication training including role-play', desc: 'Practising conversations with bereaved students and families builds staff confidence and reduces avoidance.' }
    ]
  },
  H: {
    low:  'Behaviour and academic policies may not yet account for grief-related changes, increasing the risk that students experiencing loss are managed punitively rather than supportively.',
    high: 'Your environment shows good capacity to hold grief safely while maintaining predictable routines. Capture practice examples to support consistent responses and guide new staff.',
    priorities_low: [
      { title: 'Embed grief-sensitive adjustments into existing behaviour, attendance and assessment procedures', desc: 'This means documented flexibility, not ad hoc decisions that depend on individual teachers.' },
      { title: 'Provide examples of non-punitive responses to dysregulation related to loss', desc: 'Include practical tools such as time-out arrangements, quiet spaces and flexible classroom norms.' }
    ]
  },
  O: {
    low:  'Policies and procedures may be absent, poorly understood or accessible only to certain staff. This leaves school responses dependent on individuals rather than systems, which creates inconsistency and risk.',
    high: 'Key policy and procedural elements are in place. Schedule regular reviews, test procedures through tabletop exercises and integrate lessons learned from real events.',
    priorities_low: [
      { title: 'Develop or revise a clear grief and bereavement policy', desc: 'Align it with existing critical incident procedures and ensure it addresses both death and non-death losses.' },
      { title: 'Ensure all staff know where to find the policy and how to apply it', desc: 'This includes after-hours and holiday scenarios when regular leadership may not be available.' }
    ]
  },
  R: {
    low:  'Referral pathways and follow-up processes may be unclear or dependent on particular individuals. Without consistent review, patterns of need are missed and bereaved students can fall through the gaps.',
    high: 'Referral and review processes are working reasonably well. Collect outcome data, refine pathways and ensure continuity when staff change.',
    priorities_low: [
      { title: 'Map internal and external services and create a simple referral flowchart', desc: 'Make this visible to all staff, not just counsellors and wellbeing leaders.' },
      { title: 'Establish a routine for case review and family contact at specified intervals after a death', desc: 'A calendar of significant dates should follow bereaved students across year levels and school transitions.' }
    ]
  }
};

let responses = {};
let currentPage = 0;
const totalPages = SECTIONS.length;

function getBand(avg) {
  if (avg < 2.0) return { label: 'Limited', cls: 'band-limited' };
  if (avg < 2.5) return { label: 'Emerging', cls: 'band-emerging' };
  if (avg < 3.3) return { label: 'Consolidating', cls: 'band-consolidating' };
  return { label: 'Strong', cls: 'band-strong' };
}

function getBandColor(avg) {
  if (avg < 2.0) return '#C0392B';
  if (avg < 2.5) return '#E67E22';
  if (avg < 3.3) return '#2980B9';
  return '#27AE60';
}

function startQuiz() {
  document.getElementById('page-intro').classList.remove('active');
  document.getElementById('page-quiz').classList.add('active');
  document.getElementById('progressHeader').style.display = 'flex';
  currentPage = 0;
  renderPage(currentPage);
}

function renderPage(idx) {
  const sec = SECTIONS[idx];
  const content = document.getElementById('quizContent');

  let html = `<div class="section-group">
    <div class="section-header">
      <span class="section-number">Section ${idx + 1} of ${totalPages}</span>
      <div class="section-title">${sec.title}</div>
      <div class="section-subtitle">${sec.subtitle}</div>
    </div>
    <div class="section-divider"></div>`;

  sec.questions.forEach((q, qi) => {
    const saved = responses[q.id];
    html += `<div class="question-card">
      <div class="q-label">Question ${q.id}</div>
      <div class="q-text">${q.text}</div>
      <div class="scale-wrap">`;

    for (let v = 1; v <= 4; v++) {
      const checked = saved === v ? 'checked' : '';
      html += `<div class="scale-option">
        <input type="radio" name="q${q.id}" id="q${q.id}_${v}" value="${v}" ${checked} onchange="recordAnswer(${q.id}, ${v})">
        <label class="scale-label" for="q${q.id}_${v}">
          <span class="scale-num">${v}</span>
          <span class="scale-text">${SCALE_LABELS[v-1]}</span>
        </label>
      </div>`;
    }

    html += `</div></div>`;
  });

  html += '</div>';
  content.innerHTML = html;

  document.getElementById('validationMsg').classList.remove('show');
  document.getElementById('stepIndicator').textContent = `Section ${idx + 1} of ${totalPages}`;
  document.getElementById('btnBack').style.visibility = idx === 0 ? 'hidden' : 'visible';
  document.getElementById('btnNext').textContent = idx === totalPages - 1 ? 'View my results' : 'Next';

  const answered = sec.questions.filter(q => responses[q.id] !== undefined).length;
  const overall = Object.keys(responses).length;
  updateProgress(overall);
}

function recordAnswer(qId, val) {
  responses[qId] = val;
  const answered = Object.keys(responses).length;
  updateProgress(answered);
}

function updateProgress(answered) {
  const pct = Math.round((answered / 18) * 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressCount').textContent = answered + ' / 18';
}

function goNext() {
  const sec = SECTIONS[currentPage];
  const unanswered = sec.questions.filter(q => responses[q.id] === undefined);

  if (unanswered.length > 0) {
    document.getElementById('validationMsg').classList.add('show');
    return;
  }

  document.getElementById('validationMsg').classList.remove('show');

  if (currentPage < totalPages - 1) {
    currentPage++;
    renderPage(currentPage);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  } else {
    showResults();
  }
}

function goBack() {
  if (currentPage > 0) {
    currentPage--;
    renderPage(currentPage);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
}

function domainScore(domain) {
  const items = ANCHOR_DOMAINS[domain].items;
  const scored = items.filter(i => responses[i] !== undefined);
  if (scored.length === 0) return 0;
  const sum = scored.reduce((a, b) => a + (responses[b] || 0), 0);
  return sum / scored.length;
}

function overallScore() {
  const all = Object.values(responses);
  if (all.length === 0) return 0;
  return all.reduce((a, b) => a + b, 0) / all.length;
}

function showResults() {
  updateProgress(18);
  document.getElementById('page-quiz').classList.remove('active');
  document.getElementById('page-results').classList.add('active');
  document.getElementById('progressHeader').style.display = 'none';

  const overall = overallScore();
  const overallBand = getBand(overall);

  const domainScores = {};
  Object.keys(ANCHOR_DOMAINS).forEach(d => {
    domainScores[d] = domainScore(d);
  });

  const lowestDomain = Object.entries(domainScores).sort((a,b) => a[1]-b[1])[0][0];
  const lowestName = ANCHOR_DOMAINS[lowestDomain].label;

  let overallMsg = '';
  if (overall < 2.0) overallMsg = 'Your school is at an early stage of developing grief-informed practice. The results below identify where to begin.';
  else if (overall < 2.5) overallMsg = 'Your school has some grief-informed practices in place, and there is clear room to strengthen them. The results below identify priority areas.';
  else if (overall < 3.3) overallMsg = 'Your school is consolidating its grief-informed practice. Focus on the areas below to move from consistent to embedded.';
  else overallMsg = 'Your school demonstrates strong grief-informed practice across most areas. Use the results below to maintain and build on what is working.';

  let anchorCards = '';
  const domainOrder = ['O','A','C','H','N','R'];
  const domainFullNames = {
    A: 'Awareness',
    N: 'Normalisation',
    C: 'Communication',
    H: 'Holding Environment',
    O: 'Organisational Systems',
    R: 'Referral and Review'
  };

  domainOrder.forEach(d => {
    const avg = domainScores[d];
    const band = getBand(avg);
    const pct = ((avg - 1) / 3) * 100;
    const feedback = DOMAIN_FEEDBACK[d];
    const isLow = avg < 2.5;
    const fb = isLow ? feedback.low : feedback.high;

    anchorCards += `<div class="anchor-card ${ANCHOR_DOMAINS[d].color}">
      <div class="anchor-letter">${d}</div>
      <div class="anchor-name">${domainFullNames[d]}</div>
      <div class="domain-score-row">
        <div>
          <span class="domain-score-num">${avg.toFixed(1)}</span>
          <span class="domain-score-max"> / 4.0</span>
        </div>
        <span class="domain-band-pill ${band.cls}">${band.label}</span>
      </div>
      <div class="score-bar-wrap">
        <div class="score-bar-fill" style="width: ${Math.max(pct,3)}%"></div>
      </div>
      <div class="anchor-feedback">${fb}</div>
    </div>`;
  });

  const lowestFb = DOMAIN_FEEDBACK[lowestDomain];
  let priorityItems = '';
  if (lowestFb.priorities_low) {
    lowestFb.priorities_low.forEach((p, i) => {
      priorityItems += `<div class="priority-item">
        <div class="priority-num">${i+1}</div>
        <div class="priority-content">
          <h4>${p.title}</h4>
          <p>${p.desc}</p>
        </div>
      </div>`;
    });
  }

  const html = `
    <div class="results-hero">
      <span class="intro-badge">Your results</span>
      <h2>Overall: <span class="overall-band ${overallBand.cls}">${overallBand.label}</span></h2>
      <p>${overallMsg}</p>
    </div>

    <div class="anchor-grid">${anchorCards}</div>

    <div class="priority-section">
      <h3>Where to focus first: ${domainFullNames[lowestDomain]}</h3>
      ${priorityItems}
    </div>

    <div class="cta-box">
      <h3>Take the next step</h3>
      <p>Grief Australia provides practical resources, professional development and consultancy for school communities across Australia.</p>
      <div class="cta-links">
        <a href="https://www.grief.org.au" target="_blank" class="btn-cta btn-cta-primary">Visit grief.org.au</a>
        <a href="https://www.grief.org.au" target="_blank" class="btn-cta btn-cta-outline">Download the school guide</a>
      </div>
    </div>

    <div style="text-align:center">
      <button class="btn-restart" onclick="restartQuiz()">Start again</button>
    </div>

    <p class="disclaimer">This assessment is a self-reflective tool for school leaders and staff. It is not a validated clinical instrument. Results are intended to prompt professional reflection and planning, not to assess individual competence. Grief Australia acknowledges the complexity of bereavement support and recommends seeking specialist consultation for complex circumstances.</p>
  `;

  document.getElementById('resultsContent').innerHTML = html;
  window.scrollTo({ top: 0, behavior: 'smooth' });

  // Animate bars after render
  setTimeout(() => {
    document.querySelectorAll('.score-bar-fill').forEach(bar => {
      const w = bar.style.width;
      bar.style.width = '0%';
      requestAnimationFrame(() => {
        setTimeout(() => { bar.style.width = w; }, 50);
      });
    });
  }, 100);
}

function restartQuiz() {
  responses = {};
  currentPage = 0;
  document.getElementById('page-results').classList.remove('active');
  document.getElementById('page-intro').classList.add('active');
  document.getElementById('progressHeader').style.display = 'none';
  document.getElementById('progressFill').style.width = '0%';
  document.getElementById('progressCount').textContent = '0 / 18';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>

</body>
</html>
